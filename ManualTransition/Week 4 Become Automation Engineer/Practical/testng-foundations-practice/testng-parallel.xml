<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="TestNG Parallel Suite" parallel="tests" thread-count="2" verbose="1">
    <!-- parallel="tests" means each <test> block can run in a separate thread. -->
    <test name="Smoke Suite Thread">
        <classes>
            <class name="com.techlambda.testng.foundations.tests.GroupingPracticeTest"/>
        </classes>
    </test>

    <test name="Regression Suite Thread">
        <classes>
            <class name="com.techlambda.testng.foundations.tests.ParallelExecutionPracticeTest"/>
        </classes>
    </test>
</suite>
