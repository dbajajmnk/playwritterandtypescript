{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": [
      "node",
      "@playwright/test"
    ],
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "tests/**/*.ts",
    "pages/**/*.ts",
    "test-data/**/*.ts",
    "playwright.config.ts"
  ]
}
