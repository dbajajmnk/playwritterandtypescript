{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "@playwright/test"]
  },
  "include": ["api/**/*.ts", "config/**/*.ts", "data/**/*.ts", "fixtures/**/*.ts", "tests/**/*.ts", "utils/**/*.ts"]
}
